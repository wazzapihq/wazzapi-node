{
	"name": "@wazzapi/wazzapi",
	"version": "0.5.1",
	"description": "Typed Node.js SDK for WazzAPI",
	"license": "MIT",
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"files": [
		"dist",
		"advanced-examples",
		"docs",
		"examples",
		"README.md"
	],
	"engines": {
		"node": ">=20"
	},
	"keywords": [
		"api",
		"sdk",
		"wazzapi",
		"webhook",
		"whatsapp"
	],
	"homepage": "https://github.com/wazzapihq/wazzapi-node",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/wazzapihq/wazzapi-node.git"
	},
	"bugs": {
		"url": "https://github.com/wazzapihq/wazzapi-node/issues"
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsup src/index.ts --format esm,cjs --dts --clean",
		"typecheck": "tsc --noEmit",
		"test": "bun test",
		"prepublishOnly": "bun run typecheck && bun run test && bun run build"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.3",
		"@types/node": "^24.13.3",
		"tsup": "^8.5.1",
		"typescript": "^5.9.3"
	}
}
